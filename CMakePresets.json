{
  "version": 6,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 22,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "debug",
      "displayName": "Debug client, server, and tests",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/debug",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "BUILD_TESTING": "ON",
        "WARGAME_BUILD_SERVER": "ON"
      }
    },
    {
      "name": "sanitizers",
      "displayName": "ASan and UBSan",
      "inherits": "debug",
      "binaryDir": "${sourceDir}/build/sanitizers",
      "cacheVariables": {
        "WARGAME_ENABLE_SANITIZERS": "ON"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "debug",
      "configurePreset": "debug",
      "jobs": 2
    },
    {
      "name": "sanitizers",
      "configurePreset": "sanitizers",
      "targets": ["wargame_tests", "wargame_server"],
      "jobs": 2
    }
  ],
  "testPresets": [
    {
      "name": "debug",
      "configurePreset": "debug",
      "output": {"outputOnFailure": true}
    },
    {
      "name": "sanitizers",
      "configurePreset": "sanitizers",
      "output": {"outputOnFailure": true},
      "environment": {
        "ASAN_OPTIONS": "detect_leaks=1:strict_string_checks=1",
        "UBSAN_OPTIONS": "print_stacktrace=1:halt_on_error=1"
      }
    }
  ]
}
